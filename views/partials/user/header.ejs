<!DOCTYPE html>
<html class="no-js" lang="en">

<head>
    <meta charset="utf-8">
    <title>Ariane Motors-EV franchise</title>
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="description" content="">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta property="og:title" content="">
    <meta property="og:type" content="">
    <meta property="og:url" content="">
    <meta property="og:image" content="">
    <!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Bootstrap JS bundle (includes Popper) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Favicon -->
    <link rel="shortcut icon" type="image/x-icon" href="/frontend/assets/imgs/theme/am_logo_tiny.png">
    <!-- Template CSS -->
    <link rel="stylesheet" href="/frontend/assets/css/main.css?v=3.4">
    <!--Fa icon cdn-->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
  <!--Flat icons-->
  <link rel="stylesheet" href="https://cdn-uicons.flaticon.com/uicons-regular-rounded/css/uicons-regular-rounded.css">
    <!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>

<body>

<header class="header-area header-style-1 header-height-2">
        <div class="header-top header-top-ptb-1 d-none d-lg-block">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-xl-3 col-lg-4">
                        <div class="header-info">
                            <ul>
                                <li><i class="fi-rs-smartphone"></i> <a href="#">(+01) - 2345 - 6789</a></li>
                                <li><i class="fi-rs-marker"></i><a  href="https://maps.app.goo.gl/AAHWc6y6XAq84xzX9" target="_blank">Our location</a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-xl-6 col-lg-4">
                        <div class="text-center">
                            <div id="news-flash" class="d-inline-block">
                                <ul>
                                    <li>Authorized company dealer</li>
                                    <li>Spare parts at 30% off  <a href="/shop/products"> Shop now</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-lg-4">
                        <div class="header-info header-info-right">
                            <h1>Hello World!</h1>
                            <ul>
                                <% if (!loggedUser) {%>
                                    <li><form action="/login" method="get"><button type="submit" style="border-radius: 28px;">Log In</button></form></li>

                                <% }else{ %>
                                    <li><i class="fi-rs-user"></i><a href="/account">Hello,<%=loggedUser%></a></li>
                                    <li><form action="/logout" method="post">
                                        <button type="submit" style="background-color: red;border-radius: 28px;">SIGNOUT</button>
                                    </form></li>
                                    <li><button class="btn-warning" data-bs-toggle="modal" data-bs-target="#referralModal">Refer a Friend</button></li>
                                    <%}%>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div> 
        <!-- Modal -->
<div class="modal fade" id="referralModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">Referral Code</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Ask your friend to use this coupon code to create an account and get ₹100 credited to your wallet
        <div class="p-5 d-flex justify-content-center">
            <p>Code:</p><h1 class="font-xl"><%=loggedUserReferral %></h1>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
        <div class="header-middle header-middle-ptb-1 d-none d-lg-block">
            <div class="container">
                <div class="header-wrap">
                    <div class="logo logo-width-1">
                        <a href="/"><img src="/frontend/assets/imgs/theme/am_logo.png" height="50px"  alt="logo"></a>
                    </div>
                    <div class="header-right">
                        <div class="search-style-2">

                            <form action="/shop/products/" method="get">
  <select class="select-active" name="category">
    <option value="">All Categories</option>
    <% if (categoryList) { %>
      <% categoryList.forEach(category => { %>
        <option value="<%= category._id %>" <%= category._id == categoryId ? "selected" : "" %>>
          <%= category.name %>
        </option>
      <% }) %>
    <% } %>
  </select>

    <input type="text" name="search" placeholder="Search for items..." value="<%= search || "" %>">
    <% if(!search){ %>
        <button type="submit"><i class="fi-rs-search"></i></button>
<% }else{ %>
    <a href="/shop/products">
      <button type="button" class="btn btn-close"></button>
    </a>
    <% } %>

</form>

                        </div>
                        <div class="header-action-right">
                            <div class="header-action-2">
                                <div class="header-action-icon-2">
                                    <a title="View Wishlist" href="/shop/wishlist">
                                        <img class="svgInject" alt="Evara" src="/frontend/assets/imgs/theme/icons/icon-heart.svg">
                                        <% if(wishListCount){ %>
                                        <span class="pro-count wishCount blue"><%=wishListCount %></span>
                                        <% } %>
                                    </a>
                                </div>
                                <div class="header-action-icon-2">
                                    <a title="View Cart" class="mini-cart-icon" href="/shop/cart">
                                        <img alt="Evara" src="/frontend/assets/imgs/theme/icons/icon-cart.svg">
                                        <% if(cartCount){ %>
                                            <span class="pro-count cartCount blue"><%=cartCount %></span>
                                            <% } %>
                                        </a>

                                </div>
                                 <div class="header-action-icon-2">
                                    <a title="View Profile" href="/account">
                                        <% if(loggedUser &&loggedUserImage){%>
                                            <img class="border rounded" alt="profile_Image" src="<%=loggedUserImage %>">
                                            <% }else{ %>
                                            <img class="svgInject" alt="profile_Image" src="/frontend/assets/imgs/theme/icons/icon-profile.svg">
                                            <% } %>

                                    </a>
                                </div>
                                 <div class="header-action-icon-2">
                                    <a title="My Wallet" href="/wallet">
                                    <i class="fi-rr-wallet mr-10"></i>

                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="header-bottom header-bottom-bg-color sticky-bar">
            <div class="container">
                <div class="header-wrap header-space-between position-relative">
                    <div class="logo logo-width-1 d-block d-lg-none">
                        <a href="/"><img src="/frontend/assets/imgs/theme/am_logo.png" alt="logo"></a>
                    </div>
                    <div class="header-nav d-none d-lg-flex">
                        <div class="main-categori-wrap d-none d-lg-block">

                            <div class="categori-dropdown-wrap categori-dropdown-active-large">
                                
                                </ul>
                                <div class="more_categories">Show more...</div>
                            </div>
                        </div>
                        <div class="main-menu main-menu-padding-1 main-menu-lh-2 d-none d-lg-block">
                            <nav>
                                <ul>
                                    <li>
                                        <a href="/">Home</a>
                                    </li>
                                    <li>
                                        <a href="/shop/products/">Shop</a>
                                    </li>

                                    <li><a href="#">Pages <i class="fi-rs-angle-down"></i></a>
                                        <ul class="sub-menu">

                                            <li><a href="/login">Login</a></li>
                                            <li><a href="/account">My Account</a></li>
                                            <li><a href="/wallet">My Wallet</a></li>

                                        </ul>
                                    </li>
                                    <li>

                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                    <div class="header-action-right d-block d-lg-none">
                        <div class="header-action-2">
                            <div class="header-action-icon-2 d-block d-lg-none">
                                <div class="burger-icon burger-icon-white">
                                    <span class="burger-icon-top"></span>
                                    <span class="burger-icon-mid"></span>
                                    <span class="burger-icon-bottom"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="mobile-header-active mobile-header-wrapper-style">
            <div class="mobile-header-wrapper-inner">
                <div class="mobile-header-top">
                    <div class="mobile-header-logo">
                        <a href="/"><img src="/frontend/assets/imgs/theme/am_logo.png" alt="logo"></a>
                    </div>
                    <div class="mobile-menu-close close-style-wrap close-style-position-inherit">
                        <button class="close-style search-close">
                            <i class="icon-top"></i>
                            <i class="icon-bottom"></i>
                        </button>
                    </div>
                </div>
                <div class="mobile-header-content-area">
                    <div class="mobile-search search-style-3 mobile-header-border">
                        <form action="/shop/products/" method="get">
                            <input type="text" name="search" placeholder="Search for items..." value="<%= typeof search !== 'undefined' && search ? search : '' %>">
                            <button type="submit"><i class="fi-rs-search"></i></button>
                        </form>
                    </div>
                    <div class="mobile-menu-wrap mobile-header-border">
                        <nav>
                            <ul class="mobile-menu">
                                <li class="menu-item-has-children"><span class="menu-expand"></span><a href="/">Home</a></li>
                                <li class="menu-item-has-children"><span class="menu-expand"></span><a href="/shop/products/">Shop</a></li>
                                <li class="menu-item-has-children"><span class="menu-expand"></span><a href="#">Pages</a>
                                    <ul class="dropdown">
                                        <li><a href="/login">Login</a></li>
                                        <li><a href="/account">My Account</a></li>
                                        <li><a href="/wallet">My Wallet</a></li>
                                    </ul>
                                </li>
                            </ul>
                        </nav>
                    </div>
                    <div class="mobile-header-info-wrap mobile-header-border">
                        <div class="single-mobile-header-info mt-30">
                            <a  href="https://maps.app.goo.gl/AAHWc6y6XAq84xzX9" target="_blank"><i class="fi-rs-marker"></i> Our location </a>
                        </div>
                        <% if (!loggedUser) {%>
                            <div class="single-mobile-header-info">
                                <a href="/login"><i class="fi-rs-user"></i>Log In / Sign Up </a>
                            </div>
                        <% }else{ %>
                            <div class="single-mobile-header-info">
                                <a href="/account"><i class="fi-rs-user"></i>Hello, <%=loggedUser%></a>
                            </div>
                            <div class="single-mobile-header-info">
                                <form action="/logout" method="post" style="display:inline;">
                                    <button type="submit" style="background: none; border: none; padding: 0; color: #333; font: inherit; cursor: pointer;">
                                        <i class="fi-rs-sign-out"></i>Sign Out
                                    </button>
                                </form>
                            </div>
                        <% } %>
                        <div class="single-mobile-header-info">
                            <a href="#"><i class="fi-rs-headphones"></i>(+01) - 2345 - 6789 </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>